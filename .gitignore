# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Backend config (contain credentials — use *.example.php as templates)
backend/contact/config.php
backend/download/download_config.php
backend/contact/logs/
backend/download/rate-limit/
backend/download/tmp/

# Generated WebP assets — produced at build time from assets-raw/ via npm run build:images
public/assets/
