# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Backend config (contain credentials — use *.example.php as templates)
backend/contact/config.php
backend/download/download_config.php
backend/contact/logs/
backend/download/rate-limit/
backend/download/tmp/

# Generated assets from scripts/build-images.mjs
public/assets/*

# Fonts: keep only committed self-hosted Inter files
!public/assets/fonts/
public/assets/fonts/*
!public/assets/fonts/inter-latin.woff2
!public/assets/fonts/inter-latin-ext.woff2

# Photos (logos, previews, and app icons) are generated from assets-raw/photos
# by scripts/build-images.sh and should not be committed.

# PandaCSS generated output — not used by this project, regenerated automatically
src/styled-system/
